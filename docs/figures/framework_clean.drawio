          <mxGeometry x="30" y="570" width="1260" height="40" as="geometry"/>
        </mxCell>

        <!-- Notation -->
        <mxCell id="notation_note"
          value="Notation:  X = packet sequence tensor  |  y = class label  |  z_T, z_C = logits from teacher &amp; CNN  |  tau = temperature (2.0)  |  alpha = KD mix weight&#xa;&#xa;Source: Midterm report (March 2026) + train_distill_packet.py"
          style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=0;darkOpacity=0.05;fillColor=#f8fafc;strokeColor=#cbd5e0;align=left;size=12;fontSize=9;fontColor=#64748b;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="620" width="1260" height="50" as="geometry"/>
