          <mxGeometry x="1110" y="370" width="180" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="leg_teacher" value="Teacher (Transformer)"
          style="text;strokeColor=none;fillColor=#ebf8ff;align=left;verticalAlign=middle;spacingLeft=10;fontSize=10;fontColor=#1e40af;"
          vertex="1" parent="1">
          <mxGeometry x="1110" y="400" width="175" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="leg_cnn" value="Student-I (CNN)"
          style="text;strokeColor=none;fillColor=#f5f3ff;align=left;verticalAlign=middle;spacingLeft=10;fontSize=10;fontColor=#4c1d95;"
          vertex="1" parent="1">
          <mxGeometry x="1110" y="428" width="175" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="leg_lr" value="Student-II (LR)"
          style="text;strokeColor=none;fillColor=#fef3c7;align=left;verticalAlign=middle;spacingLeft=10;fontSize=10;fontColor=#92400e;"
          vertex="1" parent="1">
          <mxGeometry x="1110" y="456" width="175" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="leg_kd" value="KD / co-distill (dashed)"
          style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;fontSize=10;fontColor=#d97706;"
          vertex="1" parent="1">
          <mxGeometry x="1110" y="484" width="175" height="22" as="geometry"/>
        </mxCell>

        <!-- Pipeline 标注 -->
        <mxCell id="pipeline_note" value="Pipeline:  1. Train teacher (X, y)  →  2. Get z_T on train set  →  3. KD train CNN  →  4. Get z_C  →  5. Fit LR (variants)"
          style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=0;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;size=12;fontSize=10;fontColor=#78350f;"
